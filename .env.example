# ============================================
# VitisTrust Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ============================================

# ===== STELLAR SOROBAN (Asset Layer) =====
# Network: testnet or mainnet
STELLAR_NETWORK=testnet
# RPC endpoint for Soroban
STELLAR_RPC_URL=https://soroban-testnet.stellar.org:443
# Oracle secret key for signing transactions
STELLAR_ORACLE_SECRET=sadasdas
# Soroban contract ID (after deploy)
SOROBAN_CONTRACT_ID=CA...
# Timeout for Stellar operations (optional, default: 60s)
STELLAR_TIMEOUT_S=60

# ===== HEDERA (Trust Layer) =====
HEDERA_ACCOUNT_ID=0.0.xxxxxx
HEDERA_DER_PRIVATE_KEY=3020...
HEDERA_TOPIC_ID=0.0.xxxxxx

# ===== SATELLITE (Sentinel Hub) =====
# https://services.sentinel-hub.com
SENTINEL_CLIENT_ID=...
SENTINEL_CLIENT_SECRET=...

# ===== AI (Groq) =====
# https://console.groq.com
AI_API_KEY=...
AI_MODEL=llama-3.3-70b-versatile
