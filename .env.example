# ============================================
# VitisTrust Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ============================================

# Rootstock Testnet
RSK_RPC_URL=https://public-node.testnet.rsk.co
RSK_ORACLE_ADDRESS=0x...
RSK_PRIVATE_KEY=0x...
RSK_CONTRACT_ADDRESS=0x...

# Hedera Testnet
HEDERA_ACCOUNT_ID=0.0.xxxxxx
HEDERA_DER_PRIVATE_KEY=3020...
HEDERA_TOPIC_ID=0.0.xxxxxx

# Sentinel Hub (https://services.sentinel-hub.com)
SENTINEL_CLIENT_ID=...
SENTINEL_CLIENT_SECRET=...

# AI (Groq - https://console.groq.com)
AI_API_KEY=...
AI_MODEL=llama-3.3-70b-versatile
